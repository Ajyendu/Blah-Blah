# Must be exactly 64 hex characters. If unset, message data is stored in plaintext.
DATA_ENCRYPTION_KEY=dfcaa824dfc0a181bb5b67f96aa6dd02cfdb81a0ad204b351618d2b50db6c57b

# Database
